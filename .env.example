# ===== FiveAvenues 配置样例 =====
# 复制为 .env 后填入实际值（.env 已被 .gitignore 忽略，不会入库）。

# ---- 基础 ----
PORT=3000
ADMIN_USER=admin
ADMIN_PASS=admin12345

# ---- FR-8：外部 WuDaDao 知识库目录 ----
# 留空：使用仓库内默认 WuDaDao/（开箱即用）。
# 配置后：系统始终从该路径读取外部知识库（支持绝对路径或 file:// URL）。
# 例如：
#   WUDADAO_KB_PATH=D:/projects/external-wudadao/WuDaDao
#   WUDADAO_KB_PATH=file:///D:/projects/external-wudadao/WuDaDao
# 若路径不存在或无读权限，网站将明确降级（不静默失败），行程仍可基于本地 data/*.json 生成。
WUDADAO_KB_PATH=

# ---- RAG（向量检索增强生成，可选）----
# 未配置 RAG_API_KEY 时，行程生成自动退化为本地规则生成。
RAG_API_KEY=
RAG_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 非标准 OpenAI 兼容网关可单独覆盖路径（默认 /embeddings、/chat/completions）：
#   RAG_EMBED_PATH=/embeddings
#   RAG_CHAT_PATH=/chat/completions
RAG_EMBED_PATH=
RAG_CHAT_PATH=
RAG_EMBED_MODEL=embedding-3
RAG_LLM_MODEL=glm-4-flash
