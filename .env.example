# ===== FiveAvenues RAG / LLM 配置（零依赖，走 Node18 全局 fetch）=====
# 复制本文件为 .env 并填入你的密钥。.env 已被 .gitignore 忽略，不会入库。
# 未配置 RAG_API_KEY 时，/api/guide 会自动降级到原有规则生成，网站照常运行。

# API Key（智谱 / 其他 OpenAI 兼容服务）
RAG_API_KEY=your-api-key-here

# 服务 Base URL（智谱默认如下；切到 DeepSeek / OpenAI 改这里）
RAG_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 向量模型（智谱 embedding-3，2048 维）
RAG_EMBED_MODEL=embedding-3

# 对话模型（glm-4-flash 便宜好用；也可 glm-4-plus / glm-4-long）
RAG_LLM_MODEL=glm-4-flash
